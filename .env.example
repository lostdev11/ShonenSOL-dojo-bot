DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id
# Optional: instant guild-scoped commands (comma-separated for multiple servers).
# Omit this (or set DISCORD_DEPLOY_GLOBAL=true) so slash commands exist in every server the bot joins.
# DISCORD_DEPLOY_GLOBAL=true
DISCORD_GUILD_ID=your_test_server_guild_id

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
