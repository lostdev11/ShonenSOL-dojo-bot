DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id
# Optional: instant guild-scoped commands (comma-separated for multiple servers).
# Omit this (or set DISCORD_DEPLOY_GLOBAL=true) so slash commands exist in every server the bot joins.
# DISCORD_DEPLOY_GLOBAL=true
DISCORD_GUILD_ID=your_test_server_guild_id
# Optional: limit dojo slash commands to specific channel IDs (comma-separated).
# Leave empty to allow commands in all channels.
# DOJO_COMMAND_CHANNEL_IDS=123456789012345678,234567890123456789

# Optional: only accept interactions from these guilds (comma-separated guild IDs).
# Use this if the bot should never run in arbitrary servers someone invites it to.
# Leave unset to allow every server the bot has joined (still protect secrets on the host).
# ALLOWED_GUILD_IDS=987654321098765432,876543210987654321

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
